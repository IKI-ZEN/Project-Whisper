# Copy this file to .dev.vars and fill in real values.
# All variables except ENVIRONMENT are optional for local dev using Workers AI.

ENVIRONMENT=development

# Required to use OpenAI, Anthropic, or Google models via Cloudflare AI Gateway.
# Without these, only @cf/... Workers AI models will work.
CLOUDFLARE_ACCOUNT_ID=
AI_GATEWAY_ID=

# API keys for flagship models (only needed if AI_GATEWAY_ID is set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=

# Optional: sign exported configs with HMAC-SHA256 so imports can verify provenance.
# Any string works — use `openssl rand -hex 32` to generate a strong secret.
SIGNING_SECRET=

# Optional: restrict CORS to specific origins (comma-separated). Defaults to '*'.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# Optional: Cloudflare Access Zero Trust authentication.
# When set, all state-mutation API endpoints (create/update/delete sandbox, build, upload)
# require a valid Cf-Access-Jwt-Assertion header. Read-only and run/stream endpoints
# remain public. Set up your Access application at dash.cloudflare.com → Access.
CF_ACCESS_AUD=             # Application Audience (AUD) tag from the Access app settings
CF_ACCESS_TEAM_DOMAIN=     # e.g. yourteam.cloudflareaccess.com
